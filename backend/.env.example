NODE_ENV=development
PORT=5020

# MongoDB (Docker: docker compose up -d mongo, then use localhost)
MONGO_URL=mongodb://localhost:27017/meydone
# Alternative name (still supported):
# MONGODB_URI=mongodb://localhost:27017/meydone

JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# --- Docker Compose ---
# Start only MongoDB:  docker compose up -d mongo
# API in Docker uses hostname `mongo`: set in compose or use:
#   MONGO_URL=mongodb://mongo:27017/meydone
# JWT_SECRET must be set for `docker compose up` when including the `api` service.

# If set, POST /api/admin/register requires header: X-Admin-Register-Secret: <same value>
# ADMIN_REGISTER_SECRET=your_long_random_secret

# Optional — used by npm run create-admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe123!
# ADMIN_NAME=Admin

# When true, the API does NOT auto-insert sample users/venues/comments on startup (default: auto-seed if DB empty).
# SKIP_AUTO_SEED=true
